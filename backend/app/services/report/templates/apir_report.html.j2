{# APIR — Axis Property Intelligence Report
   12-page Jinja template rendered by WeasyPrint into a Letter PDF.

   Inputs (passed as Jinja context by the orchestrator):
     measurements : PropertyMeasurements (Pydantic, .model_dump())
     diagrams     : dict of pre-rendered SVG strings:
                      facet_plan, pitch_view_full, pitch_view_compact,
                      footprint, soffit, measurement_key,
                      elev_front, elev_right, elev_left, elev_back

   Helper filters (registered in pdf_renderer.py):
     |linear  → "84' 11""
     |area    → "1,325 ft²"
     |squares → "13¼"
     |pct     → "12.0%"
     |ui      → "1,234"  (integer with thousands separator)
#}
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8"/>
<title>APIR — {{ measurements.job.property_address }}</title>
<style>

/* ─── @page chrome — letter, 0.65/0.75 inch margins per APIR Part 6 ─── */
@page {
  size: Letter;
  margin: 0.65in 0.75in;
  @bottom-left {
    content: "{{ measurements.job.property_address }} · {{ measurements.job.property_city }}, {{ measurements.job.property_state }} {{ measurements.job.property_zip }}";
    font-family: Inter, sans-serif; font-size: 9px; color: #888;
  }
  @bottom-center {
    content: "Job " counter(page) " · {{ measurements.job.job_id }}";
    font-family: Inter, sans-serif; font-size: 9px; color: #888;
  }
  @bottom-right {
    content: "Page " counter(page) " of " counter(pages);
    font-family: Inter, sans-serif; font-size: 9px; color: #888;
  }
}
@page :first { /* cover page has no chrome */
  margin: 0;
  @bottom-left { content: ""; }
  @bottom-center { content: ""; }
  @bottom-right { content: ""; }
}

/* ─── Global type + color tokens (APIR Part 6) ─── */
body {
  font-family: Inter, system-ui, sans-serif;
  font-size: 11px; color: #1A1A1A;
  margin: 0; padding: 0; line-height: 1.45;
}
h1, h2, h3, h4 { font-weight: 600; color: #1B3A6B; margin: 0; }
.navy { color: #1B3A6B; }
.orange { color: #E85C2C; }
.muted { color: #666; }
.tiny { font-size: 9px; color: #888; }
.pending { color: #CC7700; background: #FFF8E6; padding: 1px 4px; border-radius: 2px; }
.estimated-badge { background: #FFF8E6; color: #CC7700; padding: 2px 8px; border-radius: 10px; font-size: 9px; font-weight: 600; }

/* ─── Page wrappers ─── */
.page { page-break-after: always; }
.page:last-child { page-break-after: avoid; }

.section-title {
  font-size: 14px; font-weight: 700; color: #1B3A6B;
  border-bottom: 2px solid #1B3A6B; padding-bottom: 4px;
  margin-bottom: 12px;
}

/* ─── Tables ─── */
table { border-collapse: collapse; width: 100%; font-size: 10px; }
table th { text-align: left; font-weight: 600; color: #1B3A6B; padding: 4px 6px; border-bottom: 1px solid #1B3A6B; }
table td { padding: 3px 6px; border-bottom: 0.5px solid #E5E5E5; }
table tr:last-child td { border-bottom: 0; }
table.totals td { font-weight: 600; border-top: 1px solid #888; }

/* Selected-waste-% column highlight (APIR Part 6 spec) */
.waste-table th.selected { background: #E85C2C; color: #FFF; }
.waste-table td.selected { background: #FFF0EB; font-weight: 600; }

/* ─── Cards / stat blocks ─── */
.stat-card-row { display: flex; gap: 8px; margin-bottom: 12px; }
.stat-card {
  flex: 1; padding: 10px; border: 1px solid #DDD; border-radius: 4px;
  background: #FAFAFA; text-align: center;
}
.stat-card .value { font-size: 20px; font-weight: 700; color: #1B3A6B; line-height: 1; }
.stat-card .label { font-size: 9px; color: #888; text-transform: uppercase; margin-top: 4px; }

.two-col { display: flex; gap: 16px; }
.two-col .col { flex: 1; }
.two-col .col-55 { flex: 0 0 55%; }
.two-col .col-45 { flex: 0 0 45%; }

/* ─── Confidence badges ─── */
.conf-high { background: #DCFAE6; color: #1A7A3C; }
.conf-medium { background: #FFF8E6; color: #CC7700; }
.conf-estimated { background: #FCE5DF; color: #CC2200; }
.conf-badge { padding: 2px 8px; border-radius: 10px; font-size: 9px; font-weight: 600; }

/* ─── Cover page ─── */
.cover-wrap { width: 8.5in; height: 11in; box-sizing: border-box; }
.cover-band {
  background: #1B3A6B; color: #FFF;
  padding: 28px 36px; display: flex; justify-content: space-between; align-items: center;
}
.cover-band .brand { font-size: 16px; font-weight: 700; }
.cover-band .brand img { max-height: 40px; }
.cover-band .right { text-align: right; }
.cover-band .right .addr { font-size: 22px; font-weight: 600; }
.cover-band .right .city { font-size: 13px; opacity: 0.85; }
.cover-band .pill {
  display: inline-block; background: #E85C2C; padding: 3px 10px;
  border-radius: 10px; font-size: 10px; font-weight: 600; margin-top: 6px;
}

.cover-hero {
  width: 100%; height: 3.5in; background: #DDD; position: relative;
  display: flex; align-items: center; justify-content: center;
}
.cover-hero img { width: 100%; height: 100%; object-fit: cover; }
.cover-hero-placeholder { color: #666; font-size: 12px; }
.cover-hero .caption {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(0,0,0,0.55); color: #FFF; padding: 6px 14px;
  font-size: 9px; display: flex; justify-content: space-between;
}

.cover-bottom { display: flex; padding: 24px 0 0 0; }
.cover-bottom .prep {
  background: #1B3A6B; color: #FFF; padding: 18px 28px; width: 55%;
  font-size: 11px; line-height: 1.6;
}
.cover-bottom .prep .heading { color: #E85C2C; font-size: 11px; font-weight: 600; text-transform: uppercase; margin-bottom: 8px; }
.cover-bottom .prep .row { display: flex; }
.cover-bottom .prep .row .key { width: 70px; opacity: 0.7; }
.cover-bottom .prep .row .val { flex: 1; }
.cover-bottom .meas {
  background: #F5F5F0; padding: 18px 24px; flex: 1;
  border-left: 3px solid #E85C2C;
  font-size: 10px; line-height: 1.7;
}
.cover-bottom .meas .heading { color: #1B3A6B; font-size: 11px; font-weight: 600; text-transform: uppercase; margin-bottom: 8px; }
.cover-bottom .meas .row { display: flex; }
.cover-bottom .meas .row .key { width: 130px; }
.cover-bottom .meas .row .val { flex: 1; font-weight: 600; color: #1B3A6B; }

.cover-toc { padding: 30px 36px 0; }
.cover-toc h3 { font-size: 12px; color: #1B3A6B; border-bottom: 1px solid #DDD; padding-bottom: 4px; margin-bottom: 10px; }
.cover-toc .grid { display: flex; gap: 24px; font-size: 10px; }
.cover-toc .grid ul { flex: 1; list-style: none; margin: 0; padding: 0; }
.cover-toc .grid li { display: flex; padding: 2px 0; }
.cover-toc .grid li .name { flex: 1; }
.cover-toc .grid li .dots { flex: 1; border-bottom: 1px dotted #BBB; margin: 0 6px 4px; }
.cover-toc .grid li .num { color: #1B3A6B; font-weight: 600; }

/* ─── Diagram containers ─── */
.diagram-box { background: #FFF; border: 0.5px solid #E5E5E5; padding: 4px; margin-bottom: 8px; }
.diagram-box svg { display: block; width: 100%; height: auto; }
.diagram-caption { font-size: 9px; color: #666; font-style: italic; margin-top: 4px; }

/* ─── Waste calculator banner (Page 11) ─── */
.waste-banner {
  background: #1B3A6B; color: #FFF; padding: 14px 22px; display: flex;
  justify-content: space-between; align-items: center; margin-bottom: 14px;
}
.waste-banner .left .small { font-size: 9px; opacity: 0.7; text-transform: uppercase; }
.waste-banner .left .big { font-size: 22px; font-weight: 700; margin-top: 2px; }
.waste-banner .right { text-align: right; font-size: 9px; }
.waste-banner .right .badge {
  background: #E85C2C; padding: 2px 10px; border-radius: 10px;
  font-size: 9px; font-weight: 600; margin-top: 6px; display: inline-block;
}

.disclaimer-box {
  background: #F5F5F5; border-left: 3px solid #E85C2C; padding: 10px 14px;
  font-size: 9px; color: #444; margin-top: 14px;
}

/* ─── Photo grid (Page 12) ─── */
.photo-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.photo-cell { width: calc(33% - 6px); margin-bottom: 8px; }
.photo-cell img { width: 100%; height: 130px; object-fit: cover; display: block; border-radius: 2px; }
.photo-cell .ph { width: 100%; height: 130px; background: #EEE; display: flex; align-items: center; justify-content: center; color: #999; font-size: 10px; font-style: italic; }
.photo-cell .lbl { background: #F5F5F5; padding: 4px 6px; font-size: 9px; color: #666; }

.report-meta {
  background: #F5F5F5; border: 0.5px solid #DDD; padding: 12px 16px;
  display: flex; gap: 30px; margin-top: 14px;
}
.report-meta .col { flex: 1; font-size: 10px; }
.report-meta .row { display: flex; padding: 2px 0; }
.report-meta .row .k { width: 100px; color: #666; }
.report-meta .row .v { font-weight: 600; }

.powered-by {
  text-align: center; font-size: 8px; color: #888; margin-top: 14px;
  border-top: 0.5px solid #DDD; padding-top: 10px;
}

</style>
</head>
<body>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 1 — COVER                                                        #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page cover-wrap">
  <div class="cover-band">
    <div class="brand">
      {% if measurements.contractor.logo_url %}
        <img src="{{ measurements.contractor.logo_url }}" alt="logo"/>
      {% else %}
        {{ measurements.contractor.company_name }}
      {% endif %}
    </div>
    <div class="right">
      <div class="addr">{{ measurements.job.property_address }}</div>
      <div class="city">{{ measurements.job.property_city }}, {{ measurements.job.property_state }} {{ measurements.job.property_zip }}</div>
      <div style="margin-top: 6px;">
        <span class="pill">{{ measurements.job.report_type|replace('_', ' ')|title }} Report</span>
        <span style="font-size: 10px; margin-left: 8px;">{{ measurements.job.report_date }}</span>
      </div>
      <div style="margin-top: 6px;">
        <span class="conf-badge conf-{{ measurements.job.scale_confidence }}">
          {{ measurements.job.scale_confidence|upper }} CONFIDENCE
        </span>
      </div>
    </div>
  </div>

  <div class="cover-hero">
    {% if measurements.photos.satellite_annotated %}
      <img src="{{ measurements.photos.satellite_annotated }}" alt="satellite"/>
    {% elif measurements.photos.satellite_original %}
      <img src="{{ measurements.photos.satellite_original }}" alt="satellite"/>
    {% elif measurements.photos.front_elevation %}
      <img src="{{ measurements.photos.front_elevation }}" alt="front elevation"/>
    {% else %}
      <div class="cover-hero-placeholder">{{ measurements.job.property_address }}</div>
    {% endif %}
    <div class="caption">
      <div>Satellite view · AI annotated</div>
      <div>Scale: {{ measurements.job.scale_method|replace('_', ' ') }} ({{ measurements.job.scale_confidence }})</div>
    </div>
  </div>

  <div class="cover-bottom">
    <div class="prep">
      <div class="heading">Prepared For</div>
      <div class="row"><div class="key">Contact</div><div class="val">{{ measurements.contractor.contact_name or '—' }}</div></div>
      <div class="row"><div class="key">Company</div><div class="val" style="font-weight: 600;">{{ measurements.contractor.company_name }}</div></div>
      <div class="row"><div class="key">Address</div><div class="val">{{ measurements.contractor.address or '—' }}</div></div>
      <div class="row"><div class="key">Phone</div><div class="val">{{ measurements.contractor.phone or '—' }}</div></div>
      <div class="row"><div class="key">Email</div><div class="val">{{ measurements.contractor.email or '—' }}</div></div>
      {% if measurements.contractor.license_number %}
      <div class="row"><div class="key">License</div><div class="val">{{ measurements.contractor.license_number }}</div></div>
      {% endif %}
    </div>
    <div class="meas">
      <div class="heading">Measurements</div>
      <div class="row"><div class="key">Total Roof Area</div><div class="val">{{ measurements.roof.total_area_sqft|area }}</div></div>
      <div class="row"><div class="key">Total Roof Facets</div><div class="val">{{ measurements.roof.total_facets }}</div></div>
      <div class="row"><div class="key">Predominant Pitch</div><div class="val">{{ measurements.roof.predominant_pitch }}</div></div>
      <div class="row"><div class="key">Stories</div><div class="val">{{ measurements.roof.number_of_stories }}</div></div>
      <div class="row"><div class="key">Siding Area</div><div class="val">{{ measurements.siding.total_facade_sqft|area }}</div></div>
      <div class="row"><div class="key">Footprint Area</div><div class="val">{{ measurements.footprint.area_sqft|area }}</div></div>
      <div class="row"><div class="key">Roof Material</div><div class="val">{{ measurements.roof.material|replace('_', ' ')|title }}</div></div>
      <div class="row"><div class="key">Siding Material</div><div class="val">{{ measurements.siding.material|title }}</div></div>
    </div>
  </div>

  <div class="cover-toc">
    <h3>TABLE OF CONTENTS</h3>
    <div class="grid">
      <ul>
        <li><span class="name">Roof Summary</span><span class="dots"></span><span class="num">2</span></li>
        <li><span class="name">Siding Summary</span><span class="dots"></span><span class="num">3</span></li>
        <li><span class="name">Measurement Key</span><span class="dots"></span><span class="num">4</span></li>
        <li><span class="name">Footprint Diagram</span><span class="dots"></span><span class="num">5</span></li>
        <li><span class="name">Roof Measurements</span><span class="dots"></span><span class="num">6</span></li>
      </ul>
      <ul>
        <li><span class="name">Siding Per Elevation</span><span class="dots"></span><span class="num">7</span></li>
        <li><span class="name">Soffit</span><span class="dots"></span><span class="num">8</span></li>
        <li><span class="name">Facade Details</span><span class="dots"></span><span class="num">9</span></li>
        <li><span class="name">Openings</span><span class="dots"></span><span class="num">10</span></li>
        <li><span class="name">Waste Calculator</span><span class="dots"></span><span class="num">11</span></li>
        <li><span class="name">Property Photos</span><span class="dots"></span><span class="num">12</span></li>
      </ul>
    </div>
  </div>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 2 — ROOF SUMMARY                                                 #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">ROOF SUMMARY</div>

  {% set selected = measurements.roof.waste_calculator.roof_waste_table | selectattr('is_selected') | first %}
  <div class="stat-card-row">
    <div class="stat-card">
      <div class="value">{{ measurements.roof.total_area_sqft | int | ui }}</div>
      <div class="label">Total Area (ft²)</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ measurements.roof.total_facets }}</div>
      <div class="label">Roof Facets</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ measurements.roof.predominant_pitch }}</div>
      <div class="label">Predominant Pitch</div>
    </div>
    <div class="stat-card">
      <div class="value">{{ (measurements.roof.total_area_sqft / 100) | round(1) }}</div>
      <div class="label">Squares (0% waste)</div>
    </div>
  </div>

  <div class="two-col">
    <div class="col">
      <h4 style="font-size: 11px; margin-bottom: 6px;">Roof measurements</h4>
      <table>
        <thead><tr><th>Feature</th><th>Length</th></tr></thead>
        <tbody>
          <tr><td>Roof facets</td><td>{{ measurements.roof.total_facets }} count</td></tr>
          <tr><td>Ridges</td><td>{{ measurements.roof.lengths.ridges_ft | linear }}</td></tr>
          <tr><td>Hips</td><td>{{ measurements.roof.lengths.hips_ft | linear }}</td></tr>
          <tr><td>Valleys</td><td>{{ measurements.roof.lengths.valleys_ft | linear }}</td></tr>
          <tr><td>Rakes</td><td>{{ measurements.roof.lengths.rakes_ft | linear }}</td></tr>
          <tr><td>Eaves</td><td>{{ measurements.roof.lengths.eaves_ft | linear }}</td></tr>
          <tr><td>Step flashing</td><td>{{ measurements.roof.lengths.step_flashing_ft | linear }}</td></tr>
          <tr class="totals"><td>Drip edge / Perimeter</td><td>{{ measurements.roof.lengths.drip_edge_ft | linear }}</td></tr>
        </tbody>
      </table>

      <h4 style="font-size: 11px; margin: 14px 0 6px;">Pitch breakdown</h4>
      <table>
        <thead><tr><th>Pitch</th><th>Area</th><th>Percent</th></tr></thead>
        <tbody>
          {% for row in measurements.roof.pitch_breakdown %}
          <tr><td>{{ row.pitch }}</td><td>{{ row.area_sqft | area }}</td><td>{{ row.percentage | pct }}</td></tr>
          {% endfor %}
          <tr class="totals">
            <td>Total</td>
            <td>{{ measurements.roof.total_area_sqft | area }}</td>
            <td>100.0%</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="col">
      <h4 style="font-size: 11px; margin-bottom: 6px;">3D view — shaded by slope direction</h4>
      <div class="diagram-box">
        {{ diagrams.pitch_view_full | safe }}
      </div>
      <div class="diagram-caption">2.5D shaded view. Slope arrows show downhill direction; brighter facets face south.</div>
    </div>
  </div>

  <h4 style="font-size: 11px; margin: 16px 0 6px;">Waste factor calculations</h4>
  <table class="waste-table">
    <thead>
      <tr>
        <th></th>
        {% for row in measurements.roof.waste_calculator.roof_waste_table %}
        <th class="{{ 'selected' if row.is_selected }}">{{ row.waste_pct }}%</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Area (ft²)</td>
        {% for row in measurements.roof.waste_calculator.roof_waste_table %}
        <td class="{{ 'selected' if row.is_selected }}">{{ row.area_sqft | ui }}</td>
        {% endfor %}
      </tr>
      <tr>
        <td>Squares</td>
        {% for row in measurements.roof.waste_calculator.roof_waste_table %}
        <td class="{{ 'selected' if row.is_selected }}">{{ row.squares }}</td>
        {% endfor %}
      </tr>
    </tbody>
  </table>
  <div class="diagram-caption">★ Contractor selected waste factor — set in Axis job settings</div>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 3 — SIDING SUMMARY                                               #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">SIDING SUMMARY</div>

  <div class="two-col">
    <div class="col">
      <h4 style="font-size: 11px; margin-bottom: 6px;">Areas</h4>
      <table>
        <thead><tr><th></th><th>Siding</th><th>Other</th></tr></thead>
        <tbody>
          <tr><td>Facades</td><td>{{ measurements.siding.total_facade_sqft | area }}</td><td>{{ (measurements.siding.secondary_material_sqft or 0) | area }}</td></tr>
          <tr><td>Openings</td><td>{{ measurements.siding.openings.total_opening_sqft | area }}</td><td>0 ft²</td></tr>
          <tr><td>Trims</td><td>0 ft²</td><td>—</td></tr>
          <tr class="totals">
            <td>Total</td>
            <td>{{ (measurements.siding.total_facade_sqft + measurements.siding.openings.total_opening_sqft) | area }}</td>
            <td>{{ (measurements.siding.secondary_material_sqft or 0) | area }}</td>
          </tr>
        </tbody>
      </table>

      <h4 style="font-size: 11px; margin: 14px 0 6px;">Openings</h4>
      <table>
        <thead><tr><th></th><th>Siding</th><th>Other</th></tr></thead>
        <tbody>
          <tr><td>Window quantity</td><td>{{ measurements.siding.openings.windows | length }}</td><td>0</td></tr>
          <tr><td>Door quantity</td><td>{{ measurements.siding.openings.doors | length }}</td><td>0</td></tr>
          <tr><td>Window area</td><td>{{ measurements.siding.openings.total_window_sqft | area }}</td><td>0 ft²</td></tr>
          <tr><td>Door area</td><td>{{ measurements.siding.openings.total_door_sqft | area }}</td><td>0 ft²</td></tr>
        </tbody>
      </table>

      <h4 style="font-size: 11px; margin: 14px 0 6px;">Roofline</h4>
      <table>
        <thead><tr><th>Feature</th><th>Length</th></tr></thead>
        <tbody>
          <tr><td>Eaves fascia</td><td>{{ measurements.roof.lengths.eaves_ft | linear }}</td></tr>
          <tr><td>Rakes fascia</td><td>{{ measurements.roof.lengths.rakes_ft | linear }}</td></tr>
          <tr><td>Soffit area</td><td>{{ measurements.soffit.total_area_sqft | area }}</td></tr>
        </tbody>
      </table>
    </div>

    <div class="col">
      <h4 style="font-size: 11px; margin-bottom: 6px;">Siding waste totals</h4>
      {% for row in measurements.siding.waste_table %}
      <div style="margin-bottom: 10px;">
        <div style="font-size: 10px; font-weight: 600; color: #1B3A6B; margin-bottom: 3px;">
          {% if row.category == 'siding_trim_only' %}Siding &amp; trim only
          {% elif row.category == 'openings_lt_20sqft' %}+ Openings &lt; 20 ft²
          {% else %}+ Openings &lt; 33 ft²{% endif %}
        </div>
        <table>
          <thead><tr><th></th><th>Zero waste</th><th>+10%</th><th>+18%</th></tr></thead>
          <tbody>
            <tr><td>Area (ft²)</td><td>{{ row.zero_waste_sqft | ui }}</td><td>{{ row.plus10_sqft | ui }}</td><td>{{ row.plus18_sqft | ui }}</td></tr>
            <tr><td>Squares</td><td>{{ row.zero_waste_squares }}</td><td>{{ row.plus10_squares }}</td><td>{{ row.plus18_squares }}</td></tr>
          </tbody>
        </table>
      </div>
      {% endfor %}
      <div class="diagram-caption">First row uses facade ft² + trim/unknowns touching siding.</div>
    </div>
  </div>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 4 — MEASUREMENT KEY                                              #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">MEASUREMENT KEY</div>
  <div class="diagram-box">{{ diagrams.measurement_key | safe }}</div>
  <p style="font-size: 10px; color: #444; margin-top: 12px;">
    The diagram above illustrates the terminology used throughout this report.
    All measurements on the following pages reference these labeled components.
  </p>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 5 — FOOTPRINT                                                    #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">FOOTPRINT</div>
  <div class="diagram-box">{{ diagrams.footprint | safe }}</div>
  <div style="display: flex; justify-content: space-around; margin-top: 16px; font-size: 11px;">
    <div><strong>Stories:</strong> {{ measurements.footprint.number_of_stories }}</div>
    <div><strong>Perimeter:</strong> {{ measurements.footprint.perimeter_ft | linear }}</div>
    <div><strong>Area:</strong> {{ measurements.footprint.area_sqft | area }}</div>
  </div>
  <p class="tiny" style="margin-top: 14px; font-style: italic;">
    The footprint shape shown is generated from the contractor-drawn footprint polygon on the satellite image. It reflects the actual shape of this specific property.
  </p>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 6 — ROOF MEASUREMENTS (Detailed)                                 #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">ROOF MEASUREMENTS</div>
  <div class="two-col">
    <div class="col col-55">
      <div class="diagram-box">{{ diagrams.facet_plan | safe }}</div>
      <div class="diagram-caption">Flat unfolded plan — all facets with areas and line lengths.</div>
    </div>
    <div class="col col-45">
      <h4 style="font-size: 11px; margin-bottom: 6px;">Roof facets</h4>
      <table>
        <thead><tr><th>Facet</th><th>Area</th><th>Pitch</th><th>Slope</th></tr></thead>
        <tbody>
          {% for f in measurements.roof.facets %}
          <tr><td>{{ f.id }}</td><td>{{ f.actual_area_sqft | area }}</td><td>{{ f.pitch }}</td><td>{{ f.slope_direction }}</td></tr>
          {% endfor %}
          <tr class="totals"><td>Total</td><td>{{ measurements.roof.total_area_sqft | area }}</td><td>—</td><td>—</td></tr>
        </tbody>
      </table>

      <h4 style="font-size: 11px; margin: 14px 0 6px;">Pitch diagram</h4>
      <div class="diagram-box">{{ diagrams.pitch_view_compact | safe }}</div>
      <div class="diagram-caption">Facets shaded by pitch. Arrows show slope direction.</div>
    </div>
  </div>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 7 — SIDING PER ELEVATION                                         #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">SIDING PER ELEVATION</div>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
    <div>
      <div class="diagram-caption" style="text-align: center; font-weight: 600;">FRONT</div>
      <div class="diagram-box">{{ diagrams.elev_front | safe }}</div>
    </div>
    <div>
      <div class="diagram-caption" style="text-align: center; font-weight: 600;">RIGHT</div>
      <div class="diagram-box">{{ diagrams.elev_right | safe }}</div>
    </div>
    <div>
      <div class="diagram-caption" style="text-align: center; font-weight: 600;">LEFT</div>
      <div class="diagram-box">{{ diagrams.elev_left | safe }}</div>
    </div>
    <div>
      <div class="diagram-caption" style="text-align: center; font-weight: 600;">BACK</div>
      <div class="diagram-box">{{ diagrams.elev_back | safe }}</div>
    </div>
  </div>
  <p class="tiny" style="margin-top: 10px; font-style: italic;">
    Window and door positions reflect their actual detected positions from ground photo analysis, not evenly-spaced defaults.
  </p>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 8 — SOFFIT                                                       #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">SOFFIT</div>
  <div class="two-col">
    <div class="col">
      <div class="diagram-box">{{ diagrams.soffit | safe }}</div>
    </div>
    <div class="col">
      <h4 style="font-size: 11px; margin-bottom: 6px;">Soffit breakdown</h4>
      <table>
        <thead><tr><th>#</th><th>Depth</th><th>Length</th><th>Area</th><th>Pitch</th></tr></thead>
        <tbody>
          {% for s in measurements.soffit.breakdown %}
          <tr>
            <td>{{ s.id }}</td>
            <td>
              {% if s.depth_confidence == 'estimated' %}
              <span class="pending">{{ s.depth_in | int }}"</span>
              {% else %}{{ s.depth_in | int }}"{% endif %}
            </td>
            <td>{{ s.length_ft | linear }}</td>
            <td>{{ s.area_sqft | area }}</td>
            <td>{{ s.pitch }}</td>
          </tr>
          {% endfor %}
          <tr class="totals"><td colspan="2">Totals</td><td>{{ measurements.soffit.total_length_ft | linear }}</td><td>{{ measurements.soffit.total_area_sqft | area }}</td><td>—</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 9 — FACADE DETAILS                                               #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">FACADE DETAILS</div>
  <h4 style="font-size: 11px; margin-bottom: 6px;">Siding facades</h4>
  <table>
    <thead><tr><th>Facade</th><th>Area</th><th>Wall W×H</th><th>Openings</th><th>Shutters</th><th>Vents</th></tr></thead>
    <tbody>
      {% for e in measurements.siding.elevations %}
      <tr>
        <td>{{ e.id }} ({{ e.elevation }})</td>
        <td>{{ e.net_area_sqft | area }}</td>
        <td>{{ e.wall_width_ft | linear }} × {{ e.wall_height_ft | linear }}</td>
        <td>{{ e.openings_count }}</td>
        <td>{{ e.shutter_count }}</td>
        <td>{{ e.vent_count }}</td>
      </tr>
      {% endfor %}
      <tr class="totals">
        <td>Total</td>
        <td>{{ measurements.siding.total_facade_sqft | area }}</td>
        <td>—</td>
        <td>{{ measurements.siding.elevations | sum(attribute='openings_count') }}</td>
        <td>{{ measurements.siding.elevations | sum(attribute='shutter_count') }}</td>
        <td>{{ measurements.siding.elevations | sum(attribute='vent_count') }}</td>
      </tr>
    </tbody>
  </table>

  {% if measurements.siding.secondary_material_sqft and measurements.siding.secondary_material_sqft > 0 %}
  <h4 style="font-size: 11px; margin: 14px 0 6px;">{{ measurements.siding.secondary_material|title }} facades</h4>
  <table>
    <thead><tr><th>Facade</th><th>Area</th></tr></thead>
    <tbody>
      <tr><td>BR-1</td><td>{{ measurements.siding.secondary_material_sqft | area }}</td></tr>
    </tbody>
  </table>
  {% endif %}
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 10 — OPENINGS                                                    #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">OPENINGS</div>

  <h4 style="font-size: 11px; margin-bottom: 6px;">Windows</h4>
  <table>
    <thead>
      <tr>
        <th>Group</th><th>Group W×H</th><th>Group United"</th>
        <th>Opening</th><th>W×H</th><th>United"</th><th>Area</th>
      </tr>
    </thead>
    <tbody>
      {# Group rows first, then ungrouped windows #}
      {% for g in measurements.siding.openings.window_groups %}
        {% set members = measurements.siding.openings.windows | selectattr('window_group_id','equalto',g.id) | list %}
        {% for w in members %}
        <tr>
          {% if loop.first %}
          <td>{{ g.id }}</td>
          <td>{{ g.template_w_in }}"×{{ g.template_h_in }}"</td>
          <td>{{ g.united_inches }}"</td>
          {% else %}
          <td colspan="3"></td>
          {% endif %}
          <td>{{ w.id }}</td>
          <td>{{ w.width_in }}"×{{ w.height_in }}"</td>
          <td>{{ w.united_inches }}"</td>
          <td>{{ w.area_sqft | area }}</td>
        </tr>
        {% endfor %}
      {% endfor %}
      {% for w in measurements.siding.openings.windows if not w.window_group_id %}
      <tr>
        <td>—</td><td>—</td><td>—</td>
        <td>{{ w.id }}</td>
        <td>{{ w.width_in }}"×{{ w.height_in }}"{% if w.snapped_to_standard %} <span class="tiny">*</span>{% endif %}</td>
        <td>{{ w.united_inches }}"</td>
        <td>{{ w.area_sqft | area }}</td>
      </tr>
      {% endfor %}
      <tr class="totals">
        <td colspan="6">Total</td>
        <td>{{ measurements.siding.openings.total_window_sqft | area }}</td>
      </tr>
    </tbody>
  </table>
  <div class="diagram-caption">* Snapped to nearest standard window size within 10%</div>

  <h4 style="font-size: 11px; margin: 14px 0 6px;">Doors</h4>
  <table>
    <thead><tr><th>Opening</th><th>W×H</th><th>Area</th><th>Type</th></tr></thead>
    <tbody>
      {% for d in measurements.siding.openings.doors %}
      <tr>
        <td>{{ d.id }}</td>
        <td>{{ d.width_in }}"×{{ d.height_in }}"{% if d.snapped_to_standard %} <span class="tiny">*</span>{% endif %}</td>
        <td>{{ d.area_sqft | area }}</td>
        <td>{{ d.type|title }}</td>
      </tr>
      {% endfor %}
      <tr class="totals">
        <td colspan="2">Total</td>
        <td>{{ measurements.siding.openings.total_door_sqft | area }}</td>
        <td>—</td>
      </tr>
    </tbody>
  </table>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 11 — WASTE CALCULATOR                                            #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">WASTE CALCULATOR</div>

  <div class="waste-banner">
    <div class="left">
      <div class="small">Contractor selected waste factor</div>
      <div class="big">{{ measurements.roof.waste_calculator.roof_waste_pct }}% Roof &nbsp;/&nbsp; {{ measurements.roof.waste_calculator.siding_waste_pct }}% Siding</div>
    </div>
    <div class="right">
      <div>Set in Axis Performance · {{ measurements.job.report_date }}</div>
      <div><span class="badge">APPLIED TO REPORT</span></div>
    </div>
  </div>

  <h4 style="font-size: 11px; margin-bottom: 6px;">Roof waste calculations</h4>
  <table class="waste-table">
    <thead>
      <tr>
        <th></th>
        {% for row in measurements.roof.waste_calculator.roof_waste_table %}
        <th class="{{ 'selected' if row.is_selected }}">{{ row.waste_pct }}%</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Area (ft²)</td>
        {% for row in measurements.roof.waste_calculator.roof_waste_table %}
        <td class="{{ 'selected' if row.is_selected }}">{{ row.area_sqft | ui }}</td>
        {% endfor %}
      </tr>
      <tr>
        <td>Squares</td>
        {% for row in measurements.roof.waste_calculator.roof_waste_table %}
        <td class="{{ 'selected' if row.is_selected }}">{{ row.squares }}</td>
        {% endfor %}
      </tr>
    </tbody>
  </table>

  <h4 style="font-size: 11px; margin: 14px 0 6px;">Material quantities at selected waste factor</h4>
  <div class="two-col">
    <div class="col">
      <h5 style="font-size: 10px; color: #1B3A6B; margin-bottom: 4px;">Roofing</h5>
      <table>
        <thead><tr><th>Material</th><th>Qty</th><th>Unit</th></tr></thead>
        <tbody>
          {% set selected = measurements.roof.waste_calculator.roof_waste_table | selectattr('is_selected') | first %}
          <tr><td>Shingle squares</td><td>{{ selected.squares }}</td><td>squares</td></tr>
          <tr><td>Drip edge</td><td>{{ measurements.roof.lengths.drip_edge_ft | round | int }}</td><td>lin ft</td></tr>
          <tr><td>Ridge cap</td><td>{{ (measurements.roof.lengths.ridges_ft + measurements.roof.lengths.hips_ft) | round | int }}</td><td>lin ft</td></tr>
          <tr><td>Valley material</td><td>{{ measurements.roof.lengths.valleys_ft | round | int }}</td><td>lin ft</td></tr>
          <tr><td>Step flashing</td><td>{{ measurements.roof.lengths.step_flashing_ft | round | int }}</td><td>lin ft</td></tr>
          <tr><td>Starter strip</td><td>{{ measurements.roof.lengths.eaves_ft | round | int }}</td><td>lin ft</td></tr>
        </tbody>
      </table>
    </div>
    <div class="col">
      <h5 style="font-size: 10px; color: #1B3A6B; margin-bottom: 4px;">Siding &amp; Exterior</h5>
      <table>
        <thead><tr><th>Material</th><th>Qty</th><th>Unit</th></tr></thead>
        <tbody>
          <tr><td>Siding (net)</td><td>{{ measurements.siding.total_facade_sqft | int | ui }}</td><td>ft²</td></tr>
          <tr><td>Siding (w/ waste)</td><td>{{ (measurements.siding.total_facade_sqft * (1 + measurements.roof.waste_calculator.siding_waste_pct / 100)) | int | ui }}</td><td>ft²</td></tr>
          <tr><td>Soffit</td><td>{{ measurements.soffit.total_area_sqft | int | ui }}</td><td>ft²</td></tr>
          <tr><td>Fascia</td><td>{{ (measurements.roof.lengths.eaves_ft + measurements.roof.lengths.rakes_ft) | round | int }}</td><td>lin ft</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="disclaimer-box">
    Quantities are estimates based on AI-extracted measurements from satellite imagery and contractor-provided photographs. Verify all measurements and quantities on-site before ordering materials. Waste factor calculations do not include ridge caps, hip caps, or starter shingles for roofing — order these separately based on ridge/hip/eave linear footage above.
  </div>
</div>

{# ────────────────────────────────────────────────────────────────────── #}
{# PAGE 12 — PROPERTY PHOTOS + METADATA                                  #}
{# ────────────────────────────────────────────────────────────────────── #}
<div class="page">
  <div class="section-title">PROPERTY PHOTOS</div>

  <div class="photo-grid">
    {% set photo_set = [
      ('satellite_annotated', 'Satellite — AI annotated', measurements.photos.satellite_annotated),
      ('front_elevation', 'Front elevation', measurements.photos.front_elevation),
      ('right_elevation', 'Right elevation', measurements.photos.right_elevation),
      ('left_elevation', 'Left elevation', measurements.photos.left_elevation),
      ('back_elevation', 'Back elevation', measurements.photos.back_elevation)
    ] %}
    {% for slug, label, url in photo_set %}
    <div class="photo-cell">
      {% if url %}<img src="{{ url }}" alt="{{ label }}"/>{% else %}<div class="ph">Photo not available</div>{% endif %}
      <div class="lbl">{{ label }}</div>
    </div>
    {% endfor %}
    {% for extra in measurements.photos.additional %}
    <div class="photo-cell">
      <img src="{{ extra.url }}" alt="{{ extra.label }}"/>
      <div class="lbl">{{ extra.label }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="report-meta">
    <div class="col">
      <div class="row"><div class="k">Report ID</div><div class="v">{{ measurements.job.job_id }}</div></div>
      <div class="row"><div class="k">AI model</div><div class="v">{{ measurements.extraction_metadata.ai_model_used }}</div></div>
      <div class="row"><div class="k">Extracted</div><div class="v">{{ measurements.extraction_metadata.extraction_timestamp[:19] }}</div></div>
      <div class="row"><div class="k">Version</div><div class="v">{{ measurements.job.report_version }}</div></div>
    </div>
    <div class="col">
      <div class="row"><div class="k">Scale method</div><div class="v">{{ measurements.job.scale_method|replace('_', ' ') }}</div></div>
      <div class="row"><div class="k">Scale confidence</div><div class="v"><span class="conf-badge conf-{{ measurements.job.scale_confidence }}">{{ measurements.job.scale_confidence }}</span></div></div>
      <div class="row"><div class="k">Pixels per foot</div><div class="v">{{ measurements.job.pixels_per_foot | round(2) }}</div></div>
      <div class="row"><div class="k">Manual overrides</div><div class="v">{{ measurements.extraction_metadata.manual_overrides | length }}</div></div>
    </div>
  </div>

  <p class="tiny" style="font-style: italic; margin-top: 14px;">
    This report was generated using AI-assisted measurement technology by Axis Performance. Measurements are derived from contractor-drawn polygon outlines applied to satellite imagery, calibrated using {{ measurements.job.scale_reference_description or measurements.job.scale_method }}, and cross-referenced with contractor-provided ground photographs. Axis Performance makes no guarantees of absolute measurement accuracy. All measurements should be verified on-site prior to material ordering or contract execution.
  </p>

  <div class="powered-by">
    Powered by Axis Performance · axisperformance.io · AI by Google Gemini
  </div>
</div>

</body>
</html>
